{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{/* page-sitemap.xml — covers:
     - Home
     - Section index pages (/blogs/, /list/, /glossary/, /compare/, /case-study/, /authors/, /tools/)
     - Service/landing pages (/saas-seo-agency/, /saas-ppc/, /fintech-marketing-agency/, …)
     - Static pages (/about-us/, /contact-us/, /faqs/, /pricing/, /reviews/, /privacy-policy/, /terms-and-conditions/, …)
     - Tools (/tools/free-seo-roi-calculator/, /tools/ppc-roas-calculator/, /tools/query-fanout-analyser/)
     - Author pages (/authors/<slug>/)
     - Case studies (/case-study/<slug>/)

     Excludes individual articles in blogs/list/glossary/compare/alternative/vs
     sections (those go in their own per-section sitemaps). */}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{ $buildTime := now }}
{{ $articleSections := slice "blogs" "list" "glossary" "compare" "alternative" "vs" }}
{{ range .Site.Pages }}
  {{- $isArticlePage := and (eq .Kind "page") (in $articleSections .Section) -}}
  {{- if and (not .Params.private) (ne .Kind "404") (ne .Kind "taxonomy") (ne .Kind "term") (not $isArticlePage) -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- $lastmod := .Lastmod -}}
    {{- if $lastmod.IsZero }}{{ $lastmod = .Date }}{{ end -}}
    {{- if $lastmod.IsZero }}{{ $lastmod = $buildTime }}{{ end }}
    <lastmod>{{ $lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
  </url>
  {{- end }}
{{ end }}
</urlset>
