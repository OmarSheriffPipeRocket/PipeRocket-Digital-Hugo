{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{/* compare-sitemap.xml — vs / compare / alternative pages
     (WP's vs_page custom type maps to Hugo's /compare/ section) */}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{ $buildTime := now }}
{{ range where .Site.Pages "Section" "in" (slice "compare" "vs" "alternative") }}
  {{- if eq .Kind "page" -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- $lastmod := .Lastmod -}}
    {{- if $lastmod.IsZero }}{{ $lastmod = .Date }}{{ end -}}
    {{- if $lastmod.IsZero }}{{ $lastmod = $buildTime }}{{ end }}
    <lastmod>{{ $lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
  </url>
  {{- end }}
{{ end }}
</urlset>
