# Hugo build output (regenerated on every build)
/public/
/resources/
.hugo_build.lock
hugo_stats.json

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Env files (never commit secrets)
.env
.env.local
*.env

# Node (if you ever add JS tooling)
node_modules/
npm-debug.log*

# Logs
*.log

#credentials
/credentials/
__pycache__/
scripts/__pycache__/
tmp/
.claude/worktrees/
.claude/agents/

# Listicle rewrite working artifacts (research dossiers per slug)
/research/

# Daily refresh reports (local artifacts, not for publish)
/refresh-reports/

# Local Netlify folder
.netlify

# Deno lockfile — auto-generated by the Netlify CLI when it bundles the
# edge function (Netlify Edge Functions run on Deno). Local artifact, regenerated.
deno.lock

# Landing-page templates / mockups — local reference files for the team,
# not part of the built site (sit outside content/ and layouts/, Hugo ignores them).
/templates/

# Local video scripts (drafts, not for publish)
/video-script-*.md

# Experience Bank + style anchor — internal writing assets with client data; local only, not for publish
/data/experience-bank.md
/reference/experience-bank.md
/data/style-anchor.md
/data/style-anchor-worksheet.md
